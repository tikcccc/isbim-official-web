# Copy to .env.build, .env.build.local, or .env.build.production before running ./build.sh
# Build-time only. `NEXT_PUBLIC_*` values here are baked into the client bundle.

SWR_REGION=swr.example.com
SWR_ORG=example-org
IMAGE_NAME=isbim-official-web
DOCKER_PLATFORM=linux/amd64
PUSH_IMAGE=false

NEXT_PUBLIC_SITE_URL=https://www.isbim.com.hk
NEXT_PUBLIC_SANITY_PROJECT_ID=4y8vgu6z
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
NEXT_PUBLIC_MEDIA_URL=
NEXT_PUBLIC_VIDEO_CDN_URL=https://replace-me.example.com/video
NEXT_PUBLIC_FEATURE_VIDEO_CDN_URL=https://replace-me.example.com/assets
